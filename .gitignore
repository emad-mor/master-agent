# The boilerplate tracks the agent app, not your projects or local state.

# Project folders you drop in — they keep their own git.
workspace/*
!workspace/README.md

# App build + deps + local runtime state (also ignored by app/.gitignore).
app/node_modules
app/.next
app/data

# Large local voice assets (whisper binaries/model + Kokoro venv/models).
# The small Kokoro sidecar source (app/tts/server.py, requirements.txt,
# start-tts.ps1) IS tracked so a fresh clone can run voice; only the heavy
# per-machine bits are ignored.
app/whisper
app/tts/.venv/
app/tts/*.onnx
app/tts/*.bin
app/tts/*.log

# Secrets safety net — no .env anywhere reaches a copy, but keep the example.
**/.env
**/.env.*
!**/.env.example

# TypeScript incremental build artifacts.
**/*.tsbuildinfo

.DS_Store
*.log

# Local scratch / evaluation artifacts — not part of the app.
temp/
